{
  "name": "mgbp_0.1",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "contract",
    "cli"
  ],
  "scripts": {
    "compact": "npm -w @mgbp/mgbp-contract run compact",
    "build:contract": "npm -w @mgbp/mgbp-contract run build",
    "build:cli": "npm -w @mgbp/mgbp-cli run build",
    "build": "npm run build:contract && npm run build:cli",
    "cli": "npm run build:cli && npm -w @mgbp/mgbp-cli run start --",
    "network:up": "npm run cli -- network up",
    "network:down": "npm run cli -- network down",
    "network:status": "npm run cli -- network status",
    "typecheck": "npm -w @mgbp/mgbp-contract run typecheck && npm -w @mgbp/mgbp-cli run typecheck"
  },
  "devDependencies": {
    "@openzeppelin/compact-cli": "^0.0.2",
    "@types/node": "^25.9.3",
    "typescript": "^5.9.3"
  }
}
